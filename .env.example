# ============================================
# QQ 智能助手 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# === 前端 ===
BACKEND_URL=http://localhost:8000

# === vLLM 推理服务 ===
VLLM_BASE_URLS=http://localhost:8001
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_TIMEOUT=120
VLLM_MAX_RETRIES=3

# === 模型提供商 ===
# 可选: vllm / ollama / openai
MODEL_PROVIDER=vllm

# === 数据库 ===
DATABASE_PATH=./qq_assistant.db
# PostgreSQL 模式（可选）:
# USE_POSTGRESQL=true
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/qqassistant

# === 向量数据库 ===
VECTOR_DB_PATH=./vector_db

# === 安全配置 ===
# JWT 密钥：必须设置，至少32字符，首次启动会自动生成
# JWT_SECRET=your-secure-secret-here
JWT_ALGORITHM=HS256
# API Keys（逗号分隔，用于API Key认证）
# API_KEYS=key1,key2,key3

# === 限流配置 ===
RATE_LIMIT_RPM=300
RATE_LIMIT_TPM=500000
GENERATE_RPM=60
GENERATE_TPM=500000

# === 输入验证 ===
MAX_BODY_SIZE=1048576
PROMPT_MAX_LENGTH=10000

# === 审计日志 ===
AUDIT_LOG_DIR=./logs

# === 安全中间件开关 ===
SECURITY_MIDDLEWARE_ENABLED=true

# === Redis 缓存（可选）===
# REDIS_URL=redis://localhost:6379/0

# === CORS ===
# CORS_ORIGINS=http://localhost:5000,http://localhost:3000
