# ============================================
# QQ 智能助手 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# === 运行环境 ===
# 开发: development | 生产: production
ENVIRONMENT=development

# === 前端（Next.js）===
BACKEND_URL=http://localhost:8000

# === vLLM 推理服务 ===
# VLLM_SERVED_MODEL_NAME 必须与 vLLM --served-model-name 完全一致
VLLM_BASE_URLS=http://localhost:8001
VLLM_SERVED_MODEL_NAME=qwen3-8b-instruct-awq
VLLM_TIMEOUT=120
VLLM_MAX_RETRIES=3
VLLM_ENABLED=true

# === 模型提供商 ===
# 可选: vllm / ollama / openai
MODEL_PROVIDER=vllm

# === HuggingFace 国内镜像（加速模型下载）===
# 设为 https://hf-mirror.com 使用国内镜像
HF_ENDPOINT=https://hf-mirror.com

# === 模型与 LoRA 路径 ===
# MODEL_PATH 为相对 backend/ 的路径，backend/models 是指向 /root/autodl-tmp/models 的符号链接
# 默认使用 AWQ 4bit 量化模型（单卡 3090 约 14GB 显存）
MODEL_PATH=./models/Qwen3-8B-Instruct-AWQ
# Path as seen by the vLLM process/container when loading adapters at runtime.
VLLM_LORA_ROOT=./loras
LORA_PATH=./loras

# === 数据库（SQLite 默认）===
DATABASE_PATH=./qq_assistant.db
# PostgreSQL 生产模式（Docker Compose 自动配置）:
# USE_POSTGRESQL=true
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/qqassistant

# === 向量数据库 ===
VECTOR_DB_PATH=./vector_db


# === Persistent server runtime layout (AutoDL/Linux example) ===
# Keep these outside the Git-managed application directory.
# DATABASE_PATH=/root/autodl-tmp/qqchat-data/db/qq_assistant.db
# VECTOR_DB_PATH=/root/autodl-tmp/qqchat-data/rag/vector_db
# LORA_PATH=/root/autodl-tmp/qqchat-data/loras
# VLLM_LORA_ROOT=/root/autodl-tmp/qqchat-data/loras
# EMBEDDING_MODEL_PATH=/root/autodl-tmp/models/paraphrase-multilingual-MiniLM-L12-v2
# INTENT_MODEL_PATH=/root/autodl-tmp/qqchat-data/intent/classifier
# INTENT_SAMPLES_PATH=/root/autodl-tmp/qqchat-data/intent/samples
# === Redis 缓存（生产用）===
# RERANKER_MODEL_PATH=/root/autodl-tmp/models/bge-reranker-base
# RERANKER_ENABLED=false
# REDIS_URL=redis://localhost:6379/0

# === 安全配置 ===
# JWT 密钥：至少 32 字符，首次启动自动生成（多实例部署需手动统一）
# JWT_SECRET=your-48-char-secure-secret-here-change-in-production
JWT_ALGORITHM=HS256
# Production allows only the first bootstrap user unless explicitly enabled.
ALLOW_PUBLIC_REGISTRATION=false
# API Keys（逗号分隔，用于 API Key 认证）
# API_KEYS=key1,key2,key3
# 数据加密密钥（用于 config 表敏感字段 AES-256-GCM 加密）
# ENCRYPTION_KEY=<自动生成>

# === 限流配置 ===
RATE_LIMIT_RPM=300
RATE_LIMIT_TPM=500000
GENERATE_RPM=60
GENERATE_TPM=500000
AUTH_RPM=10
# Enable only when the backend is reachable exclusively through a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# === 输入验证 ===
MAX_BODY_SIZE=1048576
PROMPT_MAX_LENGTH=10000

# === 审计日志 ===
AUDIT_LOG_DIR=./logs

# === 安全中间件开关 ===
SECURITY_MIDDLEWARE_ENABLED=true

# === CORS ===
# 开发环境
CORS_ORIGINS=http://localhost:5000,http://localhost:3000
# 生产环境改为实际域名（逗号分隔）
# CORS_ORIGINS=https://your-domain.com

# === 日志级别（DEBUG / INFO / WARNING / ERROR）===
LOG_LEVEL=INFO
BACKEND_WORKERS=1

# === Inference admission control ===
# Keep these aligned with the vLLM capacity for the installed GPU.
LLM_MAX_CONCURRENCY=2
VLLM_MAX_CONCURRENCY=2
INFERENCE_WORKERS=2
INFERENCE_QUEUE_MAX_SIZE=100
INFERENCE_QUEUE_TIMEOUT=180
CHAT_GLOBAL_QPS=20
CHAT_CONVERSATION_QPS=1

# === 工具配置 ===
# 文件发送目录（Linux 默认用户 Home，Windows 默认 Desktop）
# Research automation (optional; never commit real credentials).
# Export these in the shell that runs the script.
# DEEPSEEK_API_KEY=replace-with-a-rotated-key
# DEEPSEEK_API_KEYS=key-a,key-b
LORA_ABLATION_TRAIN_DATA=backend/data/character_dialogues/tsukiyashiro_kisaki_train.json
# LAB_HOST=your-lab-host
# LAB_USER=your-lab-user
# LAB_SSH_KEY=~/.ssh/id_ed25519
# LAB_PASS=use-only-when-key-auth-is-unavailable
LAB_SSH_AUTO_ADD_HOST_KEY=false

# SEND_FILE_DIR=/home/user/send_files
# Production default: disabled. Enable only inside a locked-down container.
CLAW_CODE_EXECUTION_ENABLED=false
CLAW_EXECUTION_TIMEOUT=3

# === AstrBot multi-platform gateway ===
# Shared token for POST /api/integrations/astrbot/messages. Keep it identical in AstrBot plugin env.
# ASTRBOT_INTEGRATION_TOKEN=change-me-to-a-random-secret
# AstrBot management/listen port used by service status checks.
ASTRBOT_PORT=6185
# Variables consumed by astrbot_plugins/qqchat_gateway when installed in AstrBot.
QQCHAT_BACKEND_URL=http://127.0.0.1:8000
QQCHAT_TRIGGER_PREFIXES=/ai,/chat,@bot
QQCHAT_REPLY_GROUP_ALL=false
QQCHAT_BACKEND_TIMEOUT=60

# Reliability controls for AstrBot/backend boundary
ASTRBOT_ENABLED=true
ASTRBOT_QQ_ENABLED=true
ASTRBOT_TELEGRAM_ENABLED=true
ASTRBOT_WECOM_ENABLED=true
ASTRBOT_WECHAT_OFFICIAL_ENABLED=true
ASTRBOT_WECHAT_PERSONAL_ENABLED=false
QQCHAT_DEDUP_TTL=300
INTEGRATION_AUTH_TIMEOUT=3
INTEGRATION_DB_TIMEOUT=3
MODEL_INFERENCE_TIMEOUT=180
RAG_TIMEOUT=8
RAG_QUERY_CACHE_TTL=60
RAG_RETRIEVAL_CACHE_TTL=60
DB_WRITE_TIMEOUT=3

# Security controls for external integrations
# Production requires at least one non-empty AstrBot integration token.
# ASTRBOT_INTEGRATION_TOKEN=change-me-to-a-random-secret
# Optional comma-separated token rotation list; keep old and new during rotation.
# ASTRBOT_INTEGRATION_TOKENS=old-token,new-token
INTEGRATION_SIGNATURE_REQUIRED=false
INTEGRATION_SIGNATURE_SKEW_SECONDS=300
INTEGRATION_NONCE_TTL_SECONDS=300
INTEGRATION_NONCE_CACHE_MAX=10000
ASTRBOT_RAW_MAX_BYTES=65536


# === Production required deployment variables ===
# Set these explicitly before ENVIRONMENT=production. Do not keep placeholder values.
# ASTRBOT_INTEGRATION_TOKEN=replace-with-a-long-random-shared-secret
# QQCHAT_BACKEND_URL=http://backend:8000
# DATABASE_URL=postgresql+asyncpg://qqassistant:replace-password@postgres:5432/qqassistant
# VLLM_BASE_URL=http://vllm:8001
# JWT_SECRET=replace-with-at-least-32-random-characters
# ALLOWED_ORIGINS=https://your-admin.example.com
# LOG_LEVEL=INFO
# BACKEND_WORKERS=1
